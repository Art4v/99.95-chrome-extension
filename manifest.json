{
    "manifest_version": 3,
    "name": "99.95",
    "version": "1.7.0",
    "description": "Displays a class schedule countdown with integrated datasheets, Desmos, and light/dark mode.",
    "icons": {
      "16": "assets/favicon.png",
      "48": "assets/favicon.png",
      "128": "assets/favicon.png"
    },
    "permissions": [
      "storage"
    ],
    "background": {
      "service_worker": "background.js"
    },
    "action": {
      "default_popup": "popup/popup.html",
      "default_icon": {
        "16": "assets/favicon.png",
        "48": "assets/favicon.png",
        "128": "assets/favicon.png"
      }
    },
    "web_accessible_resources": [
      {
        "resources": ["timetable-preview.html", "timetable-preview.css", "timetable-preview.js"],
        "matches": ["<all_urls>"]
      }
    ]
    ,
    "content_security_policy": {
      "extension_pages": "script-src 'self'; object-src 'self'; frame-src 'self' https://www.desmos.com https://www.wolframalpha.com;"
    }
  }
  