{
    "name": "Hello Extensions",
    "description": "Base Level Extension",
    "version": "1.0",
    "manifest_version": 3,
    "permissions": ["storage"],
    "web_accessible_resources": [{
      "resources": ["libs/*"],
      "matches": ["<all_urls>"]
    }],
    "background": {
      "service_worker": "background.js"
    },
    "action": {
      "default_popup": "landing/landing.html",
      "default_icon": "assets/icon.png"
    }    
  }