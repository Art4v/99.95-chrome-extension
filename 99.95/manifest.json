{
    "manifest_version": 3,
    "name": "99.95",
    "version": "1.0.0",
    "description": "An extension to display a class schedule countdown based on the current time.",
    "icons": {
      "16": "chrome-extension/assets/favicon.png",
      "48": "chrome-extension/assets/favicon.png",
      "128": "chrome-extension/assets/favicon.png"
    },
    "permissions": [
      "storage",
      "activeTab"
    ],
    "host_permissions": [
      "http://*/",
      "https://*/"
    ],
    "background": {
      "service_worker": "background.js"
    },
    "action": {
      "default_popup": "chrome-extension/popup/popup.html",
      "default_icon": {
        "16": "chrome-extension/assets/favicon.png",
        "48": "chrome-extension/assets/favicon.png",
        "128": "chrome-extension/assets/favicon.png"
      }
    },
    "web_accessible_resources": [
      {
        "resources": ["chrome-extension/website/output.json", "chrome-extension/website/popup.html", "chrome-extension/website/landing.html", "chrome-extension/website/output.json"],
        "matches": ["<all_urls>"]
      }
    ]
  }
  